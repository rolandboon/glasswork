{
  "name": "glasswork",
  "version": "1.0.1",
  "description": "A transparent, Lambda-optimized web framework for building OpenAPI-compliant REST APIs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./list-query": {
      "types": "./dist/list-query/index.d.ts",
      "import": "./dist/list-query/index.js",
      "default": "./dist/list-query/index.js"
    },
    "./jobs": {
      "types": "./dist/jobs/index.d.ts",
      "import": "./dist/jobs/index.js",
      "default": "./dist/jobs/index.js"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js",
      "default": "./dist/email/index.js"
    },
    "./uploads": {
      "types": "./dist/uploads/index.d.ts",
      "import": "./dist/uploads/index.js",
      "default": "./dist/uploads/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js",
      "default": "./dist/observability/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "framework",
    "hono",
    "lambda",
    "serverless",
    "typescript",
    "dependency-injection",
    "awilix",
    "openapi",
    "rest-api",
    "aws-lambda",
    "valibot"
  ],
  "author": "Roland Boon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolandboon/glasswork.git"
  },
  "bugs": {
    "url": "https://github.com/rolandboon/glasswork/issues"
  },
  "homepage": "https://github.com/rolandboon/glasswork#readme",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check . --write",
    "lint:ci": "biome check .",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "smoke:pack": "node scripts/smoke-pack-consumer.mjs",
    "verify": "pnpm run typecheck && pnpm run lint:ci && pnpm run build && pnpm run test && pnpm run smoke:pack",
    "prepublishOnly": "npm run verify",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-scheduler": "^3.1000.0",
    "@aws-sdk/client-sesv2": "^3.1000.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@aws-sdk/client-ssm": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@casl/ability": "^7.0.0",
    "@casl/prisma": "^2.0.0",
    "@hono/swagger-ui": "^0.6.0",
    "@prisma/client": "^7.0.0",
    "awilix": "^13.0.0",
    "better-auth": "^1.6.0",
    "dotenv": "^17.0.0",
    "hono": "^4.12.0",
    "hono-openapi": "^1.3.0",
    "valibot": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-scheduler": {
      "optional": true
    },
    "@aws-sdk/client-sqs": {
      "optional": true
    },
    "@aws-sdk/client-cloudwatch": {
      "optional": true
    },
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/client-sesv2": {
      "optional": true
    },
    "@aws-sdk/client-ssm": {
      "optional": true
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@casl/prisma": {
      "optional": true
    },
    "@hono/swagger-ui": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "@casl/ability": {
      "optional": true
    },
    "better-auth": {
      "optional": true
    },
    "dotenv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1065.0",
    "@aws-sdk/client-dynamodb": "^3.1065.0",
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/client-scheduler": "^3.1064.0",
    "@aws-sdk/client-sesv2": "^3.1064.0",
    "@aws-sdk/client-sqs": "^3.1064.0",
    "@aws-sdk/client-ssm": "^3.1064.0",
    "@aws-sdk/lib-dynamodb": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@biomejs/biome": "^2.4.16",
    "@casl/ability": "^7.0.0",
    "@casl/prisma": "^2.0.1",
    "@hono/swagger-ui": "^0.6.1",
    "@prisma/client": "^7.8.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.13.1",
    "@vitest/coverage-v8": "^4.1.8",
    "awilix": "^13.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25",
    "hono-openapi": "^1.3.0",
    "mermaid": "^11.15.0",
    "mjml": "^5.3.0",
    "typescript": "^5.9.3",
    "valibot": "^1.4.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.13.1",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.8",
    "vue": "^3.5.35"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/valibot-validator": "^0.6.1",
    "@valibot/to-json-schema": "^1.7.1",
    "deepmerge": "^4.3.1",
    "nanoid": "^5.1.11",
    "openapi-types": "^12.1.3"
  }
}
